# Переменные для Docker (опционально)
# Скопируйте в .env при необходимости переопределить значения

# PostgreSQL (для локального подключения к БД в Docker)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/spotify_clone

# JWT (в docker-compose используются значения по умолчанию)
SECRET_KEY=super-secret-key-change-in-production-xyz123
