# Скопируйте в .env.prod и заполните. Не коммитьте .env.prod.

# PostgreSQL (должен совпадать с паролем в DATABASE_URL для backend)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=сгенерируйте_длинный_случайный_пароль
POSTGRES_DB=spotify_clone

# Публичный URL фронта (через запятую, если несколько)
CORS_ORIGINS=https://music.example.com,https://www.music.example.com

# JWT — обязательно уникальный длинный секрет (например: openssl rand -base64 48)
SECRET_KEY=

ADMIN_EMAILS=you@example.com

JAMENDO_CLIENT_ID=

# Порт на хосте для nginx со статикой (по умолчанию 80)
FRONTEND_HTTP_PORT=80
